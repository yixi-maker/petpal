# ============================================================
# PetPal V1 Environment Configuration
# For beta/staging, copy to .env.staging and fill in values
# See docs/beta-readiness.md for detailed instructions
# ============================================================
# Copy to .env and fill in values for your environment.
# NEVER commit .env to version control.
# ============================================================

# --- Environment ---
NODE_ENV=development
# staging: NODE_ENV=production APP_ENV=staging
# production: NODE_ENV=production APP_ENV=production

# --- Database ---
# development: SQLite (no setup needed)
DATABASE_URL="file:./prisma/dev.db"
# staging/production (PostgreSQL):
# DATABASE_URL="postgresql://user:password@host:5432/petpal?schema=public"

# --- Session Security ---
# REQUIRED for staging & production: generate with `openssl rand -base64 64`
SESSION_SECRET="petpal-dev-secret-at-least-32-chars-long!!"
ADMIN_SESSION_SECRET="petpal-admin-dev-secret-32-chars!!"

# --- Admin ---
# REQUIRED for staging & production:
# ADMIN_USERNAME="admin"
# ADMIN_PASSWORD_HASH="<generate with: node -e "const b=require('bcryptjs');b.hash('your-pw',10).then(h=>console.log(h))">"

# --- Redis (optional, for code store & rate limiting) ---
# staging/production (strongly recommended):
# REDIS_URL="redis://localhost:6379"
# CODE_STORE=redis      # 'memory' (default) | 'redis'
# RATE_LIMIT_STORE=redis # 'memory' (default) | 'redis'

# --- SMS Provider ---
# development: SMS_PROVIDER=mock (code 123456, no real send)
# staging/production: SMS_PROVIDER=aliyun
# SMS_ACCESS_KEY=""
# SMS_SECRET=""
# SMS_SIGN_NAME=""
# SMS_TEMPLATE_ID=""

# --- AI Provider ---
# development: AI_PROVIDER=mock
# staging/production: AI_PROVIDER=openai or AI_PROVIDER=zhipu
# AI_API_KEY=""
# AI_MODEL="gpt-4o-mini"

# --- Storage (file uploads) ---
# development: STORAGE_PROVIDER=local
# staging/production: STORAGE_PROVIDER=s3
# STORAGE_ENDPOINT=""
# STORAGE_BUCKET=""
# STORAGE_ACCESS_KEY=""
# STORAGE_SECRET_KEY=""
# STORAGE_REGION=""

# --- Content Moderation ---
# development: MODERATION_PROVIDER=mock (keyword filter)
# staging/production: MODERATION_PROVIDER=aliyun
# MODERATION_API_KEY=""

# --- Maps ---
# Required for staging/production:
# NEXT_PUBLIC_AMAP_KEY=""
# NEXT_PUBLIC_AMAP_SECURITY_JS_CODE=""

# --- Public URL (used for share links, redirects) ---
# NEXT_PUBLIC_APP_URL="https://your-domain.com"

# --- Error Monitoring (optional) ---
# SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_DSN=""
